  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e6e6fa10",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#c3b1e1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#e6e6fa"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c3b1e1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.tag"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#e6e6fa"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    },
    {
      "scope": [
        "entity.name.section",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#c3b1e1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#e6e6fa10"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.parameters"
      ],
      "settings": {
        "foreground": "#e6e6fa"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#c3b1e1"
      }
    }
  ]
}