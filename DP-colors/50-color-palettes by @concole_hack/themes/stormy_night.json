  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#c8d6e510",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#48dbfb",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#c8d6e5"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "storage.type"
      ],
      "settings": {
        "foreground": "#48dbfb",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.tag"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#c8d6e5"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    },
    {
      "scope": [
        "entity.name.section",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#48dbfb",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#c8d6e510"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.parameters"
      ],
      "settings": {
        "foreground": "#c8d6e5"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#48dbfb"
      }
    }
  ]
}