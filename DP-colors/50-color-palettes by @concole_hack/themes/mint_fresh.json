  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#1b5e2010",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.template",
        "string.quoted",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#00acc1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1b5e20"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "storage.type"
      ],
      "settings": {
        "foreground": "#00acc1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.tag"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#1b5e20"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    },
    {
      "scope": [
        "entity.name.section",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#00acc1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.directive",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#1b5e2010"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.parameters"
      ],
      "settings": {
        "foreground": "#1b5e20"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#00acc1"
      }
    }
  ]
}