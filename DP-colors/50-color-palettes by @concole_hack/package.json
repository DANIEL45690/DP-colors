{
  "name": "50-color-palettes",
  "displayName": "50 Color Palettes",
  "description": "50 профессиональных цветовых палитр для VS Code",
  "version": "1.0.0",
  "publisher": "colorpalettes",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onView:colorPalettesView",
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "color-palettes-sidebar",
          "title": "Color Palettes",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "color-palettes-sidebar": [
        {
          "id": "colorPalettesView",
          "name": "Color Palettes"
        }
      ]
    },
    "commands": [
      {
        "command": "colorPalettes.applyTheme",
        "title": "Apply Color Palette"
      },
      {
        "command": "colorPalettes.refreshPalettes",
        "title": "Refresh Palettes"
      },
      {
        "command": "colorPalettes.exportPalette",
        "title": "Export Palette"
      },
      {
        "command": "colorPalettes.openView",
        "title": "Open Color Palettes"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "colorPalettes.refreshPalettes",
          "group": "navigation",
          "when": "view == colorPalettesView"
        }
      ]
    },
    "configuration": {
      "title": "50 Color Palettes",
      "properties": {
        "colorPalettes.animationSpeed": {
          "type": "number",
          "default": 300,
          "description": "Animation speed in milliseconds"
        },
        "colorPalettes.defaultView": {
          "type": "string",
          "enum": [
            "grid",
            "list"
          ],
          "default": "grid",
          "description": "Default view mode"
        }
      }
    },
    "themes": [
      {
        "label": "Color Palettes - Midnight Dream",
        "path": "./themes/midnight_dream.json",
        "uiTheme": "vs-dark"
      },
      {
        "label": "Color Palettes - Sunset Blaze",
        "path": "./themes/sunset_blaze.json",
        "uiTheme": "vs-dark"
