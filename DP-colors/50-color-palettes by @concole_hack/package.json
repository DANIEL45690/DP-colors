{
  "name": "dp-colors",
  "displayName": "🎨 DP-colors",
  "description": "✨ 50+ элегантных цветовых палитр для VS Code | Мгновенная смена темы, создание своих палитр, экспорт/импорт",
  "version": "1.0.0",
  "publisher": "DanielLasmskov",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielLasmskov/dp-colors"
  },
  "homepage": "https://github.com/DanielLasmskov/dp-colors",
  "bugs": {
    "url": "https://github.com/DanielLasmskov/dp-colors/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "color palette",
    "dark theme",
    "light theme",
    "custom theme",
    "colorful",
    "palettes",
    "vscode-theme",
    "dp-colors"
  ],
  "activationEvents": [
    "onView:colorPalettesView",
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "color-palettes-sidebar",
          "title": "Color Palettes",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "color-palettes-sidebar": [
        {
          "id": "colorPalettesView",
          "name": "🎨 Color Palettes"
        }
      ]
    },
    "commands": [
      {
        "command": "colorPalettes.openView",
        "title": "🎨 Open Color Palettes",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.applyTheme",
        "title": "✨ Apply Theme",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.searchPalettes",
        "title": "🔍 Search Palettes",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.randomTheme",
        "title": "🎲 Random Theme",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.cycleThemes",
        "title": "🔄 Cycle Themes",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.toggleAutoCycle",
        "title": "⏱️ Toggle Auto-Cycle",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.exportPalette",
        "title": "💾 Export Palette",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.importPalette",
        "title": "📥 Import Palette",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.createCustomPalette",
        "title": "🖌️ Create Custom Palette",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.deleteCustomPalette",
        "title": "🗑️ Delete Custom Palette",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.showPaletteInfo",
        "title": "ℹ️ Show Palette Info",
        "category": "DP-colors"
      },
      {
        "command": "colorPalettes.refreshPalettes",
        "title": "🔄 Refresh Palettes",
        "category": "DP-colors",
        "icon": "$(refresh)"
      },
      {
        "command": "colorPalettes.resetToDefault",
        "title": "⚙️ Reset to Default",
        "category": "DP-colors"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "colorPalettes.refreshPalettes",
          "group": "navigation",
          "when": "view == colorPalettesView"
        }
      ],
      "view/item/context": [
        {
          "command": "colorPalettes.applyTheme",
          "group": "inline",
          "when": "viewItem == palette"
        },
        {
          "command": "colorPalettes.showPaletteInfo",
          "group": "group1",
          "when": "viewItem == palette"
        },
        {
          "command": "colorPalettes.exportPalette",
          "group": "group1",
          "when": "viewItem == palette"
        },
        {
          "command": "colorPalettes.deleteCustomPalette",
          "group": "group2",
          "when": "viewItem == palette && viewItem =~ /custom/"
        }
      ]
    },
    "keybindings": [
      {
        "command": "colorPalettes.randomTheme",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "colorPalettes.cycleThemes",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "colorPalettes.searchPalettes",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      }
    ],
    "configuration": {
      "title": "🎨 DP-colors",
      "properties": {
        "colorPalettes.animationSpeed": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 2000,
          "description": "⚡ Animation speed when switching themes (milliseconds)"
        },
        "colorPalettes.defaultView": {
          "type": "string",
          "enum": [
            "grid",
            "list"
          ],
          "default": "grid",
          "description": "📐 Default view mode for the palette explorer"
        },
        "colorPalettes.autoCycleInterval": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "⏱️ Auto-cycle interval in seconds"
        },
        "colorPalettes.enableAnimations": {
          "type": "boolean",
          "default": true,
          "description": "✨ Enable/disable theme transition animations"
        }
      }
    },
    "themes": [
